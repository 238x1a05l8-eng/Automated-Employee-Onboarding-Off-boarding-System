7. Duplicate Prevention Logic
def prevent_duplicate_employee(db, email):
    existing = db.query(Employee).filter_by(email=email).first()

    if existing:
        raise Exception("Employee already exists")
8. Audit-Based Integrity Verification

Every change must be traceable.

class AuditService:

    def log(self, employee_id, action):
        entry = AuditLog(
            id=f"log_{datetime.utcnow().timestamp()}",
            employee_id=employee_id,
            action=action,
            timestamp=datetime.utcnow()
        )
        db.add(entry)
        db.commit()
9. Offboarding Integrity Rules
def offboard_employee(employee_id):
    employee = db.query(Employee).get(employee_id)

    if employee.status == "EXITED":
        raise Exception("Employee already offboarded")

    revoke_all_access(employee_id)

    employee.status = "EXITED"
    employee.exit_date = datetime.utcnow()

    db.commit()
