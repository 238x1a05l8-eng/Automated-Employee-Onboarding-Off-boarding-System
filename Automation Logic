8. Time-Based Automation
8.1 Scheduled Job Engine
from datetime import datetime, timedelta

class Scheduler:

    def deactivate_inactive_users(self, employees):
        for e in employees:
            if e["last_login"] < datetime.utcnow() - timedelta(days=30):
                self.disable_account(e["id"])
8.2 Retention Automation
def archive_old_employees(employees):
    for e in employees:
        if e["status"] == "EXITED" and e["exit_date"] < cutoff_date:
            archive_employee(e["id"])
