🔐 Access Control (RBAC) – Code Design
Core idea

Users → Roles → Permissions → Systems/Resources

Example:

HR Admin → can create employees
IT Admin → can provision access
Manager → can approve onboarding/offboarding
📦 1. Data Models (Roles & Permissions)
from sqlalchemy import Column, String, ForeignKey
from sqlalchemy.ext.declarative import declarative_base

Base = declarative_base()


class Role(Base):
    __tablename__ = "roles"

    id = Column(String, primary_key=True)
    name = Column(String, unique=True)  # HR_ADMIN, IT_ADMIN, MANAGER


class Permission(Base):
    __tablename__ = "permissions"

    id = Column(String, primary_key=True)
    action = Column(String)   # CREATE_EMPLOYEE, APPROVE_EXIT
    resource = Column(String) # EMPLOYEE, ACCESS, DOCUMENT


class RolePermission(Base):
    __tablename__ = "role_permissions"

    id = Column(String, primary_key=True)
    role_id = Column(String, ForeignKey("roles.id"))
    permission_id = Column(String, ForeignKey("permissions.id"))
👤 2. User Role Mapping
class UserRole(Base):
    __tablename__ = "user_roles"

    id = Column(String, primary_key=True)
    user_id = Column(String)
    role_id = Column(String, ForeignKey("roles.id"))
🧠 3. Access Control Engine (Core Logic)
class AccessControlService:

    def __init__(self, db_session):
        self.db = db_session

    def get_user_roles(self, user_id):
        return self.db.query(UserRole).filter_by(user_id=user_id).all()

    def get_role_permissions(self, role_id):
        return self.db.query(RolePermission).filter_by(role_id=role_id).all()

    def has_permission(self, user_id, action, resource) -> bool:
        user_roles = self.get_user_roles(user_id)

        for user_role in user_roles:
            permissions = self.get_role_permissions(user_role.role_id)

            for rp in permissions:
                perm = self.db.query(Permission).filter_by(
                    id=rp.permission_id,
                    action=action,
                    resource=resource
                ).first()

                if perm:
                    return True

        return False
🛡️ 4. Permission Guard (Decorator Style)
from fastapi import HTTPException

def require_permission(action: str, resource: str):
    def wrapper(func):
        def inner(*args, **kwargs):
            user_id = kwargs.get("user_id")
            acl: AccessControlService = kwargs.get("acl")

            if not acl.has_permission(user_id, action, resource):
                raise HTTPException(status_code=403, detail="Access Denied")

            return func(*args, **kwargs)
        return inner
    return wrapper
⚙️ 5. Example Usage in APIs
@require_permission("CREATE_EMPLOYEE", "EMPLOYEE")
def create_employee(user_id: str, data: dict, acl: AccessControlService):
    print("Employee created:", data)
    return {"status": "success"}
🔄 6. Role Assignment Service
class RoleAssignmentService:

    def __init__(self, db_session):
        self.db = db_session

    def assign_role(self, user_id: str, role_id: str):
        mapping = UserRole(
            id=f"ur_{user_id}_{role_id}",
            user_id=user_id,
            role_id=role_id
        )

        self.db.add(mapping)
        self.db.commit()
🔐 7. Offboarding Access Revocation
class AccessRevocationService:

    def __init__(self, db_session):
        self.db = db_session

    def revoke_all_access(self, user_id: str):
        roles = self.db.query(UserRole).filter_by(user_id=user_id).all()

        for role in roles:
            self.db.delete(role)

        self.db.commit()

